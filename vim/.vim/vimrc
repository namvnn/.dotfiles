let mapleader = ' '

filetype plugin indent on

set autoindent
set autoread
set clipboard=unnamed,unnamedplus
set colorcolumn=100
set completeopt=fuzzy,menu,menuone,popup,noselect
set grepformat=%f:%l:%c:%m
set grepprg=rg\ --vimgrep
set hidden
set hlsearch
set incsearch
set laststatus=2
set noswapfile
set number
set relativenumber
set ruler
set scrolloff=8
set signcolumn=yes
set smartcase
set textwidth=100
set ttimeout
set ttimeoutlen=50
set wildmenu
set wildoptions=pum,tagfile

" Indentation
set shiftwidth=4
set expandtab
set smarttab
set softtabstop=4
set tabstop=4

" Colorscheme
syntax on
let &background = $THEME_MODE
set notermguicolors
colorscheme memono

" Move to window
nnoremap <Leader>h <C-W>h
nnoremap <Leader>j <C-W>j
nnoremap <Leader>k <C-W>k
nnoremap <Leader>l <C-W>l

" Yank the current file path
nnoremap yp <Cmd>call setreg('+', expand('%:p'))<CR>

" Keep searching centered
nnoremap n nzzzv
nnoremap N Nzzzv

" Keep half-window scrolling centered
nnoremap <C-D> <C-D>zz
nnoremap <C-U> <C-U>zz

" Navigate quickfix list and keep it centered
nnoremap <C-K> <Cmd>cprev<CR>zz
nnoremap <C-J> <Cmd>cnext<CR>zz

" Better indenting
vnoremap < <gv
vnoremap > >gv

" Replace currently selected text with black hole register without yanking it
vnoremap <Leader>p "_dP

" Replace word under cursor
nnoremap <Leader>s :%s/\<<C-R><C-W>\>/<C-R><C-W>/gI<Left><Left><Left>

" Create or edit file
nnoremap <Leader>e :e <C-R>=expand('%:p:h') . '/'<CR>

" Make the current buffer a scratch buffer
nnoremap <Leader>bs <Cmd>setlocal bt=nofile bh=wipe noswf nobl<CR>

" Yank til the end
nnoremap Y y$

" Clear highlighting search
nnoremap <silent> <C-L> :nohlsearch<C-R>=has('diff')?'<Bar>diffupdate':''<CR><CR><C-L>

" Set a new undo point before deleting text in insert mode
inoremap <C-U> <C-G>u<C-U>
inoremap <C-W> <C-G>u<C-W>

" Switch between C source and header file
nnoremap <Leader>cc <Cmd>e %:p:s,.h$,.X123X,:s,.c$,.h,:s,.X123X$,.c,<CR>

" Enable manpage
runtime ftplugin/man.vim

" Disable netrw
let g:loaded_netrw = 1
let g:loaded_netrwPlugin = 1

" Enable editorconfig
packadd! editorconfig
