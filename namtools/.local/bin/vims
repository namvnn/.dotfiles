#!/usr/bin/env bash

# Author: Nam Nguyen <nam.vnngu@gmail.com>
# Description: Secured Vim to avoid storing progress data
# License: MIT License
# Reference: https://jrnl.sh/en/stable/privacy-and-security
# Date Created: January 26, 2026
# Date Modified: June 23, 2026

vim -c 'set viminfo= noswapfile noundofile nobackup nowritebackup noshelltemp history=0 nomodeline secure' "${@}"
